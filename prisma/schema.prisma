datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum EscrowStatus {
  funds_deposited
  milestone_1_released
  completed
  disputed
}

model User {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String          @unique @db.VarChar(255)
  password_hash String          @db.VarChar(512)
  role_flags    String          @db.VarChar(4) // 4-bit representation mapped to [Founder, Creator, Investor, Consumer]
  is_verified   Boolean         @default(false)
  created_at    DateTime        @default(now()) @db.Timestamptz

  founder_profile  FounderProfile?
  creator_profile  CreatorProfile?
  investor_profile InvestorProfile?
  escrow_creator   EscrowDeal[]     @relation("CreatorDeals")
  escrow_founder   EscrowDeal[]     @relation("FounderDeals")

  @@map("users")
}

model FounderProfile {
  id                       String  @id @db.Uuid
  user                     User    @relation(fields: [id], references: [id], onDelete: Cascade)
  company_name             String  @db.VarChar(255)
  legal_entity_identifier  String  @db.VarChar(100)
  pitch_deck_url           String  @db.VarChar(2048) // Authenticated Cloudflare R2 / AWS S3 reference only
  funding_goal             Decimal @db.Decimal(15, 2)

  @@map("founder_profiles")
}

model CreatorProfile {
  id               String @id @db.Uuid
  user             User   @relation(fields: [id], references: [id], onDelete: Cascade)
  handle           String @db.VarChar(100)
  bio              String @db.Text
  primary_platform String @db.VarChar(50)
  audience_size    String @db.VarChar(50)
  engagement_rate  String @db.VarChar(20)
  top_sectors      String @db.Text // Comma-separated list or tags
  past_sponsors    String @db.Text // Comma-separated list or tags

  @@map("creator_profiles")
}

model InvestorProfile {
  id             String   @id @db.Uuid
  user           User     @relation(fields: [id], references: [id], onDelete: Cascade)
  fund_name      String   @db.VarChar(255)
  tagline        String   @db.VarChar(255)
  location       String   @db.VarChar(255)
  aum            Decimal? @db.Decimal(15, 2)
  focus_sectors  String   @db.Text
  min_check_size Decimal  @db.Decimal(15, 2)
  max_check_size Decimal  @db.Decimal(15, 2)

  @@map("investor_profiles")
}

model EscrowDeal {
  id                String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  creator_id        String       @db.Uuid
  founder_id        String       @db.Uuid
  contracted_amount Decimal      @db.Decimal(12, 2)
  escrow_status     EscrowStatus

  creator           User         @relation("CreatorDeals", fields: [creator_id], references: [id], onDelete: Restrict)
  founder           User         @relation("FounderDeals", fields: [founder_id], references: [id], onDelete: Restrict)

  @@map("escrow_deals")
}
